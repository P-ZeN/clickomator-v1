{
    "$schema": "../node_modules/@tauri-apps/cli/schema.json",
    "build": {
        "beforeBuildCommand": "npm run build",
        "beforeDevCommand": "npm run dev",
        "frontendDist": "../dist",
        "devUrl": "http://localhost:8080"
    },
    "bundle": {
        "active": true,
        "category": "Music",
        "copyright": "ZeN",
        "targets": "all",
        "externalBin": [],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": "",
            "wix": {
                "language": "fr-FR"
            }
        },
        "longDescription": "",
        "macOS": {
            "entitlements": null,
            "exceptionDomain": "",
            "frameworks": [],
            "providerShortName": null,
            "signingIdentity": null
        },
        "resources": [],
        "shortDescription": "Métronome audio et visuel",
        "linux": {
            "deb": {
                "depends": [],
                "desktopTemplate": "main.desktop"
            }
        }
    },
    "productName": "Clickomator V1.1",
    "mainBinaryName": "clickomator",
    "version": "2.0.4",
    "identifier": "clickomator.v1.1",
    "plugins": {},
    "app": {
        "windows": [
            {
                "fullscreen": true,
                "height": 600,
                "resizable": true,
                "title": "Clickomator",
                "width": 800,
                "decorations": false,
                "visible": true,
                "additionalBrowserArgs": " --enable-ui-devtools",
                "useHttpsScheme": true
            }
        ],
        "security": {
            "csp": "default-src 'self' tauri: asset: https://asset.localhost; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline' asset: https://asset.localhost; script-src 'self' tauri: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost 'self' tauri: asset: https://asset.localhost;"
        }
    }
}

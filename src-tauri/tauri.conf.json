{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:8080",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Clickomator V1.1",
    "version": "0.1.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "process": {
        "exit": true
      },
      "window": {
        "all": false,
        "close": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Music",
      "copyright": "ZeN",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "../public/32x32.png",
        "../public/128x128.png",
        "../public/128x128@2x.png",
        "../public/favicon.ico"
      ],
      "identifier": "clickomator.v1.1",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Métronome audio et visuel",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": true,
        "height": 600,
        "resizable": true,
        "title": "Clickomator",
        "width": 800,
        "decorations": true
      }
    ]
  }
}

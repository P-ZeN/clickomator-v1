{
    "$schema": "../node_modules/@tauri-apps/cli/schema.json",
    "app": {
        "windows": [
            {
                "fullscreen": true,
                "height": 800,
                "width": 1200,
                "resizable": true,
                "title": "Clickomator",
                "decorations": false,
                "visible": true
            }
        ]
    },
    "bundle": {
        "targets": [
            "deb",
            "appimage",
            "rpm"
        ],
        "linux": {
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libgtk-3-0",
                    "libayatana-appindicator3-1"
                ],
                "desktopTemplate": "main.desktop"
            }
        }
    }
}

